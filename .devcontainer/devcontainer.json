{
  "name": "Obsidian Agent",
  "image": "mcr.microsoft.com/devcontainers/dotnet:10.0",
  "forwardPorts": [5120],
  "postCreateCommand": "dotnet restore",
  "remoteEnv": {
    "AI_ENDPOINT": "http://host.docker.internal:12434/engines/v1",
    "AI_MODEL": "ai/gpt-oss",
    "ASPNETCORE_ENVIRONMENT": "Development"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit"
      ]
    }
  }
}
